# Python cache/bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment/secrets
.env
.env.*
!.env.example

# Local database and runtime artifacts
*.db
*.sqlite3

# Keep only versioned instance assets required by exports
instance/*
!instance/README.md
!instance/logsheet_template.xlsx

# Backups and temporary outputs
backups/
instance/backups/
*.bak
*.tmp

# Build and packaging outputs
build/
dist/*
!dist/PCR_BATO_Desktop.exe

# Test and coverage artifacts
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# IDE/OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
